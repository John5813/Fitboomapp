{
  "expo": {
    "name": "Fitboom",
    "slug": "fitboom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitboom",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1229"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yaqin atrofdagi zallarni ko'rsatish uchun joylashuvingiz kerak",
        "NSCameraUsageDescription": "QR kodni skanerlash va chek rasmini tushirish uchun kamera kerak",
        "NSPhotoLibraryUsageDescription": "Chek rasmini yuborish uchun rasmlar kerak",
        "NSLocationAlwaysUsageDescription": "Yaqin atrofdagi zallarni ko'rsatish uchun joylashuvingiz kerak"
      }
    },
    "android": {
      "package": "com.javlon5813.fitboom",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B1229"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-location",
      [
        "expo-camera",
        {
          "cameraPermission": "QR kodni skanerlash uchun kameraga ruxsat kerak"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Chek rasmini yuborish uchun ruxsat kerak",
          "cameraPermission": "Chek rasmini tushirish uchun ruxsat kerak"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "4d77dde7-6475-40f8-b380-e10951c3e0c4"
      }
    },
    "owner": "javlon5813"
  }
}
